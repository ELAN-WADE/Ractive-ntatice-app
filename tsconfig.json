{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@turf/boolean-point-in-polygon": [
        "node_modules/@turf/boolean-point-in-polygon/dist/js/index.d.ts"
      ],
      "@turf/helpers": [
        "node_modules/@turf/helpers/dist/js/index.d.ts"
      ]
    },
    "strict": true,
    "skipDefaultLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
